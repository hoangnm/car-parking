#!/bin/sh
echo "Auto-formatting code with Spotless..."

# Run Spotless to apply formatting
./gradlew spotlessApply
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo "Spotless failed to apply formatting. Commit aborted."
    exit 1
fi

# Find all Java files that were originally staged for this commit
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.java$")

# Re-stage them in case Spotless formatted them
if [ -n "$STAGED_JAVA_FILES" ]; then
    for FILE in $STAGED_JAVA_FILES; do
        git add "$FILE"
    done
fi

echo "Code formatted and added to commit!"
exit 0
